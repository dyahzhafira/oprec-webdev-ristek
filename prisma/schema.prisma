generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id  String @id @default(cuid())
  email String @unique
  password String
  name  String?
  forms Form[]
}

model Form {
  id  String  @id @default(cuid())
  title String
  description String?
  userId  String
  user  User  @relation(fields: [userId], references: [id])
  questions Question[]
  responses Response[]
  createdAt DateTime  @default(now())
  status String @default("Draft")
}

model Question {
  id  String @id @default(cuid())
  label String
  type String
  required Boolean @default(false)
  options String? 
  formId String
  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)
}

model Response {
  id String @id @default(cuid())
  formId String
  form Form @relation(fields: [formId], references: [id])
  answers String
  createdAt DateTime @default(now())
}